rules_version = '2';

// =============================================================
// 共有 Firestore Rules — Firebase プロジェクト: proclink-8d582
//
// このファイルは proclink8.0 と renova18.5 が共用する唯一のルールです。
// 変更時は必ず両アプリへの影響を確認してからデプロイしてください。
//
//   [SHARED]   両アプリが使用
//   [PROCLINK] proclink8.0 のみ使用
//   [RENOVA]   renova18.5  のみ使用
//
// デプロイ手順:
//   1. このファイル (proclink8.0/firestore.rules) を編集
//   2. cp firestore.rules "../renova project/renova18.5/firestore.rules"
//   3. firebase deploy --only firestore:rules
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------
    // 共通ヘルパー関数 [SHARED]
    // -------------------------------------------------------

    function isLogin() {
      return request.auth != null;
    }

    function isOwner(projectId) {
      return request.auth != null
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid
          == request.auth.uid;
    }

    function isAdmin(projectId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role == "admin";
    }

    function isManager(projectId) {
      return request.auth != null
        && (isOwner(projectId) || isAdmin(projectId));
    }

    function isProjectMember(projectId) {
      return request.auth != null
        && (
          isManager(projectId)
          || exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid))
        );
    }

    function isPhotoPublic(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/public/config)
        && get(/databases/$(database)/documents/projects/$(projectId)/public/config).data.photoPublic == true;
    }

    function isProjectOwnerUid(uid, projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId))
        && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == uid;
    }

    // [RENOVA] renovaGroups のメンバー判定
    function isRenovaGroupMember(groupId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/renovaGroups/$(groupId)/members/$(request.auth.uid));
    }

    // [ADMIN] renova-admin の管理者判定（admin/{uid} ドキュメントの有無）
    function isSystemAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // -------------------------------------------------------
    // shareCodes [SHARED]
    // -------------------------------------------------------
    match /shareCodes/{code} {
      allow read: if true;
      allow write: if isLogin();
    }

    // -------------------------------------------------------
    // projects [SHARED]
    // -------------------------------------------------------
    match /projects/{projectId} {
      allow read: if isLogin();

      allow create: if isLogin()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if isOwner(projectId)
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if isOwner(projectId);
    }

    match /projects/{projectId}/public/config {
      allow read: if true;
      allow create, update, delete: if isManager(projectId);
    }

    // [SHARED] boardPdfs — proclink: PDF出力保存 / renova: 黒板PDF保存
    match /projects/{projectId}/boardPdfs/{docId} {
      allow read: if true;
      allow write: if isLogin();
    }

    // [SHARED] laundry / laundryStatus
    match /projects/{projectId}/laundry/{docId} {
      allow read: if true;
      allow write: if isLogin();
    }

    match /projects/{projectId}/laundryStatus/{docId} {
      allow read: if true;
      allow write: if isLogin();
    }

    // [SHARED] members
    match /projects/{projectId}/members/{uid} {
      allow read: if isProjectMember(projectId);
      allow create: if isLogin() && request.auth.uid == uid;
      allow update: if isOwner(projectId)
        || (isLogin() && request.auth.uid == uid
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role);
      allow delete: if isOwner(projectId) || (isLogin() && request.auth.uid == uid);
    }

    // -------------------------------------------------------
    // users [SHARED]
    // -------------------------------------------------------
    match /users/{uid} {
      // read: 写真撮影者名の解決（proclink usePhotoUsers）等で
      //       他ユーザーの基本プロフィールを参照するため全ログインユーザー可
      allow read: if isLogin();
      allow write: if isLogin() && request.auth.uid == uid;
    }

    match /users/{uid}/myProjects/{projectId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
      // プロジェクトのownerはメンバーのmyProjectsを更新・削除できる（除名・ブロック用）
      allow update, delete: if isOwner(projectId);
    }

    // [RENOVA] users 直下テンプレート
    match /users/{uid}/stepTemplates/{templateId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    match /users/{uid}/overallTemplates/{templateId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    // [SHARED] 旧 users/{uid}/projects ツリー（互換用）
    match /users/{uid}/projects/{projectId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    match /users/{uid}/projects/{projectId}/{document=**} {
      allow read: if isLogin()
        && (
          request.auth.uid == uid
          || (isProjectOwnerUid(uid, projectId) && isProjectMember(projectId))
        );

      allow write: if isLogin()
        && (
          request.auth.uid == uid
          || (isProjectOwnerUid(uid, projectId) && isManager(projectId))
        );
    }

    // [SHARED] residentNoticeTemplates
    match /users/{uid}/residentNoticeTemplates/{docId} {
      allow read: if isLogin() && request.auth.uid == uid;

      allow create, update: if isLogin()
        && request.auth.uid == uid
        && request.resource.data.title is string
        && request.resource.data.text is string
        && request.resource.data.createdBy == uid;

      allow delete: if isLogin() && request.auth.uid == uid;
    }

    match /users/{uid}/residentNoticeTemplateOverrides/{templateId} {
      allow read: if isLogin() && request.auth.uid == uid;

      allow create, update: if isLogin()
        && request.auth.uid == uid
        && request.resource.data.createdBy == uid
        && (!("title" in request.resource.data) || request.resource.data.title is string)
        && (!("greeting" in request.resource.data) || request.resource.data.greeting is string)
        && (!("body" in request.resource.data) || request.resource.data.body is string)
        && (!("periodNote" in request.resource.data) || request.resource.data.periodNote is string)
        && (!("workItems" in request.resource.data) || request.resource.data.workItems is list)
        && (!("cautions" in request.resource.data) || request.resource.data.cautions is list)
        && (!("note" in request.resource.data) || request.resource.data.note is string);

      allow delete: if isLogin() && request.auth.uid == uid;
    }

    // -------------------------------------------------------
    // proclinkMember / reNovaMember [SHARED]
    // -------------------------------------------------------
    match /proclinkMember/{memberId} {
      // read: プロジェクトメンバー一覧等で他ユーザーのプロフィール名を
      //       解決するため全ログインユーザー可（両アプリで使用）
      allow read: if isLogin();

      allow create: if isLogin()
        && (
          request.auth.uid == memberId
          || request.resource.data.uid == request.auth.uid
        );

      allow update: if isLogin()
        && (
          request.auth.uid == memberId
          || resource.data.uid == request.auth.uid
          || request.resource.data.uid == request.auth.uid
        );

      allow delete: if false;
    }

    match /proclinkMember/{uid}/residentNoticeTemplates/{docId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    match /proclinkMember/{uid}/residentNoticeTemplateOverrides/{templateId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    match /reNovaMember/{memberId} {
      // read: 管理者一覧・チャット表示名等で他ユーザーのプロフィールを
      //       解決するため全ログインユーザー可（両アプリで使用）
      allow read: if isLogin();

      allow create: if isLogin()
        && (
          request.auth.uid == memberId
          || request.resource.data.uid == request.auth.uid
        );

      allow update: if isLogin()
        && (
          request.auth.uid == memberId
          || resource.data.uid == request.auth.uid
          || request.resource.data.uid == request.auth.uid
        );

      allow delete: if false;
    }

    // [PROCLINK] craftsmen — 作業員プロフィール
    // ログイン画面・メンバー一覧で他ユーザーの名前解決に使用
    // （旧キャッチオール read: isLogin() に依存していたため明示化）
    match /craftsmen/{uid} {
      allow read: if isLogin();
      allow create, update: if isLogin() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /reNovaMember/{uid}/residentNoticeTemplates/{docId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    match /reNovaMember/{uid}/residentNoticeTemplateOverrides/{templateId} {
      allow read, write: if isLogin() && request.auth.uid == uid;
    }

    // -------------------------------------------------------
    // Photos [SHARED] — 写真撮影・閲覧
    // 変更時は proclink カメラ画面・renova 黒板機能の両方を確認
    // -------------------------------------------------------
    match /projects/{projectId}/subtitles/{subtitleId}/workTypes/{workTypeId}/photos/{photoId} {
      allow read: if isProjectMember(projectId) || isPhotoPublic(projectId);

      // ✅ クライアント時刻比較・厳密フィールド検証を排除してシンプル化
      //    (shotAt <= request.time はデバイス時刻ズレで失敗するため削除)
      allow create: if isProjectMember(projectId)
        && request.auth != null
        && request.resource.data.shotByUid == request.auth.uid
        && request.resource.data.projectId == projectId;

      // ✅ 工程設定に合わせて stepId/sectionId のみ変更可
      allow update: if isManager(projectId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["stepId", "sectionId"])
        && request.resource.data.projectId == resource.data.projectId
        && request.resource.data.subtitleId == resource.data.subtitleId
        && request.resource.data.workTypeId == resource.data.workTypeId
        && request.resource.data.shotByUid == resource.data.shotByUid;

      allow delete: if isProjectMember(projectId)
        && (
          isManager(projectId)
          || request.auth.uid == resource.data.shotByUid
        );
    }

    // [SHARED] photoExportJobs
    match /photoExportJobs/{jobId} {
      allow read, write: if request.auth != null;
    }

    // -------------------------------------------------------
    // subtitles / workTypes / steps [PROCLINK]
    // renova では使用しないが Firebase は共通のため共存
    // -------------------------------------------------------
    match /projects/{projectId}/subtitles/{subtitleId} {
      allow read: if isProjectMember(projectId) || isPhotoPublic(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    match /projects/{projectId}/subtitles/{subtitleId}/workTypes/{workTypeId} {
      allow read: if isProjectMember(projectId) || isPhotoPublic(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    match /projects/{projectId}/subtitles/{subtitleId}/workTypeSections/{sectionId} {
      allow read: if isProjectMember(projectId) || isPhotoPublic(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    match /projects/{projectId}/subtitles/{subtitleId}/workTypes/{workTypeId}/steps/{stepId} {
      allow read: if isProjectMember(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    match /projects/{projectId}/subtitles/{subtitleId}/workTypes/{workTypeId}/stepSections/{sectionId} {
      allow read: if isProjectMember(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    // [PROCLINK] 工程スケジュール
    match /projects/{projectId}/scheduleData/{docId} {
      allow read: if isProjectMember(projectId);
      allow create, update, delete: if isManager(projectId);
    }

    // -------------------------------------------------------
    // Excel / AI 機能 [RENOVA]
    // proclink では使用しない
    // -------------------------------------------------------
    match /projects/{projectId}/excelImports/{document=**} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }

    match /projects/{projectId}/materialCalcs/{calcId} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }

    match /projects/{projectId}/aiDictionaries/{document=**} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }

    match /projects/{projectId}/excelSumsSaved/{sumId} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }

    match /projects/{projectId}/excelSumDraft/{uid} {
      allow read, write: if isProjectMember(projectId) && request.auth.uid == uid;
    }

    match /projects/{projectId}/excelSumDraft/{uid}/rowChunks/{chunkId} {
      allow read, write: if isProjectMember(projectId) && request.auth.uid == uid;
    }

    // -------------------------------------------------------
    // DM / チャット / 居住者通知 [RENOVA]
    // proclink では使用しない
    // -------------------------------------------------------
    match /projects/{projectId}/dmRooms/{roomId}/messages/{messageId} {
      allow read: if isProjectMember(projectId);

      allow create: if isProjectMember(projectId)
        && request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.toUid is string
        && exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.resource.data.toUid))
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasAll([request.auth.uid]);

      allow update: if isProjectMember(projectId)
        && request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readBy"])
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasAll(resource.data.readBy)
        && request.resource.data.readBy.hasAll([request.auth.uid]);

      allow delete: if false;
    }

    match /projects/{projectId}/chatRooms/{roomId} {
      allow read: if isProjectMember(projectId);
      allow create, update: if isProjectMember(projectId);
      allow delete: if false;
    }

    match /projects/{projectId}/chatRooms/{roomId}/messages/{messageId} {
      allow read: if isProjectMember(projectId);

      allow create: if isProjectMember(projectId)
        && request.auth != null
        && request.resource.data.senderUid == request.auth.uid;

      allow update: if isProjectMember(projectId)
        && request.auth != null
        && resource.data.senderUid == request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.senderName == resource.data.senderName
        && request.resource.data.senderRole == resource.data.senderRole
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.text == resource.data.text
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "fileUrl",
          "fileName",
          "fileType",
          "fileSize",
        ]);

      allow delete: if false;
    }

    match /projects/{projectId}/chatRooms/{roomId}/readStates/{uid} {
      allow read: if isProjectMember(projectId);

      allow create, update: if isProjectMember(projectId)
        && request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.projectId == projectId;

      allow delete: if false;
    }

    match /projects/{projectId}/residentMessages/{messageId} {
      allow read: if isProjectMember(projectId);

      allow create: if isManager(projectId);

      allow update: if (
          isManager(projectId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "text",
            "updatedAt",
            "targetScope",
            "targetGroupTitle",
            "templateId",
            "templateTitle",
          ])
        )
        || (
          isProjectMember(projectId)
          && request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readBy"])
        );

      allow delete: if isManager(projectId);
    }

    match /residentMembers/{uid} {
      allow read: if request.auth != null
        && (
          request.auth.uid == uid
          || (
            resource.data.projectId is string
            && isProjectMember(resource.data.projectId)
          )
        );

      allow create: if request.auth != null
        && (
          request.auth.uid == uid
          || (
            request.resource.data.projectId is string
            && isManager(request.resource.data.projectId)
          )
        );

      allow update: if request.auth != null
        && (
          request.auth.uid == uid
          || (
            request.resource.data.projectId is string
            && isManager(request.resource.data.projectId)
          )
        );

      allow delete: if request.auth != null
        && (
          request.auth.uid == uid
          || (
            resource.data.projectId is string
            && isManager(resource.data.projectId)
          )
        );
    }

    // -------------------------------------------------------
    // userTemplates [SHARED]
    // -------------------------------------------------------
    match /userTemplates/{userId}/stepTemplates/{templateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /userTemplates/{userId}/overallTemplates/{templateId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // -------------------------------------------------------
    // renovaGroups [RENOVA]
    // proclink では使用しない
    // -------------------------------------------------------
    match /renovaGroups/{groupId} {
      allow read: if isLogin();
      allow create, update, delete: if false;
    }

    match /renovaGroups/{groupId}/members/{uid} {
      allow read: if isLogin();
      allow create, update, delete: if false;
    }

    match /renovaGroups/{groupId}/dmRooms/{roomKey}/messages/{messageId} {
      allow read: if isRenovaGroupMember(groupId);

      allow create: if isRenovaGroupMember(groupId)
        && request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.toUid is string
        && exists(/databases/$(database)/documents/renovaGroups/$(groupId)/members/$(request.resource.data.toUid))
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasAll([request.auth.uid]);

      allow update: if isRenovaGroupMember(groupId)
        && request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readBy", "acceptedBy"])
        && (!("readBy" in request.resource.data) || (
          request.resource.data.readBy is list
          && request.resource.data.readBy.hasAll(resource.data.readBy)
          && request.resource.data.readBy.hasAll([request.auth.uid])
        ))
        && (!("acceptedBy" in request.resource.data) || (
          request.resource.data.acceptedBy is list
          && (!("acceptedBy" in resource.data) || request.resource.data.acceptedBy.hasAll(resource.data.acceptedBy))
          && request.resource.data.acceptedBy.hasAll([request.auth.uid])
        ));

      allow delete: if false;
    }

    match /renovaGroups/{groupId}/groupChats/{roomKey}/messages/{messageId} {
      allow read: if isRenovaGroupMember(groupId);

      allow create: if isRenovaGroupMember(groupId)
        && request.auth != null
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasAll([request.auth.uid]);

      allow update: if isRenovaGroupMember(groupId)
        && request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["readBy", "acceptedBy"])
        && (!("readBy" in request.resource.data) || (
          request.resource.data.readBy is list
          && request.resource.data.readBy.hasAll(resource.data.readBy)
          && request.resource.data.readBy.hasAll([request.auth.uid])
        ))
        && (!("acceptedBy" in request.resource.data) || (
          request.resource.data.acceptedBy is list
          && (!("acceptedBy" in resource.data) || request.resource.data.acceptedBy.hasAll(resource.data.acceptedBy))
          && request.resource.data.acceptedBy.hasAll([request.auth.uid])
        ));

      allow delete: if false;
    }

    // -------------------------------------------------------
    // 共通ユーティリティ [SHARED]
    // -------------------------------------------------------
    match /deviceBindings/{deviceId} {
      allow read, write: if isLogin();
    }

    match /publicWorkTemplates/{templateId} {
      allow read: if isLogin();
      allow create, update, delete: if isLogin();
    }

    // [PROCLINK] 英語版公開テンプレート（lang === "en" 時に使用）
    match /publicWorkTemplates-en/{templateId} {
      allow read: if isLogin();
      allow create, update, delete: if isLogin();
    }

    // [RENOVA] 解約申請 — 本人のみ作成・参照・取下げ可
    match /cancelRequests/{requestId} {
      allow read: if isLogin() && resource.data.uid == request.auth.uid;
      allow create: if isLogin()
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isLogin() && resource.data.uid == request.auth.uid;
    }

    match /proclinkWorkTypeCodes/{codeId} {
      allow read: if isLogin();
      allow create, update: if isLogin();
      allow delete: if false;
    }

    // [ADMIN] 英語版工種コード（renova-admin の設定画面で使用）
    match /proclinkWorkTypeCodes-en/{codeId} {
      allow read: if isLogin();
      allow create, update: if isLogin();
      allow delete: if false;
    }

    match /admin/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // [ADMIN/RENOVA] 紹介者
    // read: 本人に加え、renova-admin の管理者は全件一覧（紹介者選択UI）で使用
    match /referrers/{uid} {
      allow read: if isSystemAdmin()
        || (request.auth != null && request.auth.uid == uid);
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // [ADMIN] 紹介者の顧客一覧 — 書き込みはサーバー(Admin SDK)のみ
    match /referrers/{uid}/customers/{customerId} {
      allow read: if isSystemAdmin()
        || (request.auth != null && request.auth.uid == uid);
      allow write: if false;
    }

    // [ADMIN] 初期費用申請 — 管理者のみ閲覧、書き込みはサーバーのみ
    match /renovaInitialFeeRequests/{requestId} {
      allow read: if isSystemAdmin();
      allow write: if false;
    }

    // [CRAFTSMAN] renovaMembers — renova-craftsman1.1 の chatProfile が参照
    // （おそらく reNovaMember の誤記由来の legacy 参照。データは存在しない想定だが、
    //   read を拒否すると getDoc が例外になりチャット表示名解決が壊れるため許可）
    match /renovaMembers/{uid} {
      allow read: if isLogin();
      allow write: if false;
    }

    // -------------------------------------------------------
    // キャッチオール — 未定義コレクションは一切アクセス不可
    // ⚠️ 旧設定 (read: if isLogin()) は OR 評価により上記の
    //    細かい read 制限を全て無効化していたため false に変更。
    //    新しいコレクションを使う場合は必ず明示ルールを追加すること。
    // -------------------------------------------------------
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
